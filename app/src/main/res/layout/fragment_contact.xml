<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".ui.ContactFragment">

        <!-- Header Background -->
        <View
            android:id="@+id/header_bg"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/primary_eatik"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title_contact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/hubungi_kami"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="48dp"
            android:gravity="center"
            android:text="@string/contact_subtitle"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title_contact" />

        <!-- Card Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="140dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/saluran_komunikasi"
                    android:textColor="@color/text_title"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- WhatsApp -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_whatsapp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/wa_chat"
                    android:textColor="@color/accent_green"
                    android:gravity="start|center_vertical"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_call"
                    app:iconTint="@color/accent_green"
                    app:iconPadding="16dp" />

                <!-- Email -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_email"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/email_support"
                    android:textColor="@color/primary_eatik"
                    android:gravity="start|center_vertical"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_dialog_email"
                    app:iconTint="@color/primary_eatik"
                    app:iconPadding="16dp" />

                <!-- Instagram / Social -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_instagram"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/instagram_handle"
                    android:textColor="@color/accent_orange"
                    android:gravity="start|center_vertical"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_gallery"
                    app:iconTint="@color/accent_orange"
                    app:iconPadding="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#F0F0F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lokasi_restoran"
                    android:textColor="@color/text_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/alamat_restoran"
                    android:textColor="@color/text_body"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_maps"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/lihat_maps"
                    android:textColor="@color/primary_eatik"
                    app:icon="@android:drawable/ic_dialog_map"
                    app:iconTint="@color/primary_eatik" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
